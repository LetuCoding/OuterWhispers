<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" noNamespaceSchemaLocation="../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <ui:VisualElement name="DeathScreen" style="flex-grow: 1; left: 0; top: 1px; right: 0; bottom: 0; align-content: auto; align-self: auto; align-items: auto; position: absolute; background-color: rgba(0, 0, 0, 0); border-top-width: 0; border-right-width: 0; border-bottom-width: 0; border-left-width: 0; border-left-color: rgb(0, 0, 0); border-top-color: rgb(0, 0, 0); border-right-color: rgb(0, 0, 0); border-bottom-color: rgb(0, 0, 0); font-size: 24px; -unity-text-align: middle-center; color: rgb(135, 222, 165);">
        <ui:GroupBox name="GroupBox" style="align-self: center; position: absolute; left: 0%; right: 0%; height: auto; width: 100%; top: auto; bottom: 30%;">
